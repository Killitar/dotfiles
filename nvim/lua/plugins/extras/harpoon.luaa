return {
  {
    "ThePrimeagen/harpoon",
    event = "VeryLazy",
    keys = {
      {
        "<leader>a",
        function()
          require("harpoon.mark").add_file()
        end,
        desc = "Harpoon add file",
      },
      {
        "<leader>m",
        function()
          require("harpoon.ui").toggle_quick_menu()
        end,
        desc = "Harpoon toggle ui",
      },
    },
    opts = {},
  },
}
